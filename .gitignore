# Python caches
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Logs and run outputs
*.log
logs/
run_history/
runs/*
!runs/latest/
!runs/latest/reports/
!runs/latest/reports/**
artifacts/
tmp/
temp/

# Data storage (large / generated)
data/raw/
data/archive/
data/processed/
*.parquet
*.feather
*.h5
*.hdf5

# Environment and secrets
.env
.env.*
!.env.example
secrets/
*.pem
*.key

# OS files
.DS_Store
Thumbs.db

# Keep v2 runs package code trackable
!v2/src/mqre_v2/runs/
!v2/src/mqre_v2/runs/*.py
!v2/tests/runs/
!v2/tests/runs/*.py
